# ══════════════════════════════════════════════════════════
#  Fardax Store — Environment Variables
#  Copy ke .env.local (dev) atau .env (production), isi semua.
# ══════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# ─── SUPABASE (WAJIB) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# Service role key — bypass RLS, JANGAN pernah expose ke client/browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ─── APP URL (WAJIB) — satu-satunya var URL yang dibaca kode.
# WEBSITE_URL / STORE_URL TIDAK dipakai di manapun, jangan diisi di sini.
NEXT_PUBLIC_APP_URL=https://fardax.web.id

# ─── GOOGLE LOGIN (native, bukan lewat redirect Supabase) ──
# Ambil dari Google Cloud Console -> APIs & Services -> Credentials ->
# OAuth 2.0 Client ID (tipe "Web application").
# - Authorized JavaScript origins: isi domain kamu (https://fardax.web.id)
# - Client Secret TIDAK dipakai kode di sini (alur ID-token client-side tidak
#   butuh server-side code exchange), tapi tetap isi di Supabase Dashboard ->
#   Authentication -> Providers -> Google supaya Supabase bisa verifikasi
#   audience token-nya. Simpan juga di sini sekadar dokumentasi/cadangan.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── CRON SECRET (WAJIB — generate baru) ──────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pasang juga di cPanel Cron Job sebagai header: Authorization: Bearer <ini>
CRON_SECRET=GANTI_STRING_RANDOM_DI_SINI

# ─── RATE LIMIT — Upstash Redis (WAJIB) ───────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── WHATSAPP BOT (WAJIB kalau pakai bot) ─────────────────
# WHATSAPP_BOT_TOKEN harus SAMA PERSIS dengan BOT_TOKEN di .env bot.
WHATSAPP_BOT_URL=https://c733e1b3.thg-cloudhost.biz.id
WHATSAPP_BOT_TOKEN=
CS_PHONE=

# ─── OKECONNECT PROXY (relay digabung ke bot WA — lihat README bot) ──
# OKECONNECT_PROXY_URL = <WHATSAPP_BOT_URL>/relay/okeconnect
# OKECONNECT_PROXY_SECRET harus SAMA PERSIS dengan OKECONNECT_RELAY_SECRET
# di .env bot.
OKECONNECT_PROXY_URL=https://c733e1b3.thg-cloudhost.biz.id/relay/okeconnect
OKECONNECT_PROXY_SECRET=

# ─── CASAKU & OKECONNECT (kredensial akun) — biasanya diisi lewat
# Admin Panel -> Pengaturan -> Env Pembayaran (disimpan di Supabase),
# env di sini cuma fallback kalau belum diisi lewat panel.
OKECONNECT_API_URL=https://h2h.okeconnect.com
OKECONNECT_MEMBER_ID=
OKECONNECT_PIN=
OKECONNECT_PASSWORD=
CASAKU_BASE_URL=
CASAKU_LICENSE_KEY=
CASAKU_QR_ID=
CASAKU_WEBHOOK_SECRET=

# ─── EMAIL — Resend (opsional) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# ─── SMM PANEL (opsional) ─────────────────────────────────
SMM_PANEL_API_URL=
SMM_PANEL_API_KEY=

# ─── ENKRIPSI (kalau dipakai untuk simpan data sensitif) ──
ENCRYPTION_KEY=
