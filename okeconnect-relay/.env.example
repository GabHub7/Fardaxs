PORT=3000

# String random panjang, bebas. Harus sama persis dengan nilai
# OKECONNECT_PROXY_SECRET yang diisi di panel admin Fardaxs
# (Pengaturan -> Env Pembayaran) atau di Vercel Environment Variables.
RELAY_SECRET=ganti-dengan-string-acak-panjang

# Biasanya tidak perlu diubah.
OKECONNECT_BASE_URL=https://h2h.okeconnect.com
