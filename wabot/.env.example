PORT=3001

# Token rahasia yang memvalidasi request masuk/keluar antara bot ini dan
# website. Nilai ini HARUS SAMA PERSIS dengan WHATSAPP_BOT_TOKEN yang
# disetel di environment variable website (Vercel) — keduanya dipakai untuk
# kedua arah: website -> bot (kirim notifikasi) dan bot -> website
# (checkout, topup, cek status pesanan dari chat WA).
BOT_TOKEN=ganti-dengan-token-rahasia-yang-sama-dengan-WHATSAPP_BOT_TOKEN-di-website

STORE_NAME=Fardax Store
STORE_URL=https://fardaxstore.com

# Base URL website (dipakai bot untuk memanggil /api/products,
# /api/checkout/bot, /api/wallet/topup/bot, /api/orders/by-number/*).
# Saat testing, arahkan ke deployment Vercel preview/production kamu, mis.
# https://fardaxs.vercel.app — pastikan tanpa trailing slash.
WEBSITE_URL=https://fardaxstore.com

AUTH_DIR=./auth_info
CS_PHONE=+6281234567890
